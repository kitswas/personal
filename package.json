{
	"name": "personal",
	"version": "0.1.0",
	"description": "Personal Finance should be private.",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"lint": "biome check src e2e",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e:prepare": "tauri build --debug",
		"test:e2e:run": "playwright test",
		"test:e2e:report": "playwright show-report",
		"test:e2e": "pnpm test:e2e:prepare && pnpm test:e2e:run",
		"docs:graph": "depcruise src --include-only \"src/\" --output-type dot > docs/dependency-graph.dot && dot -Tsvg docs/dependency-graph.dot -o docs/dependency-graph.svg",
		"docs:all": "pnpm docs:graph",
		"prepare": "husky"
	},
	"license": "MIT",
	"dependencies": {
		"@tauri-apps/api": "^2.11.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@unovis/solid": "^1.4.3",
		"@unovis/ts": "^1.4.3",
		"solid-js": "^1.9.3",
		"ts-pattern": "^5.9.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@playwright/test": "^1.61.1",
		"@tauri-apps/cli": "^2.11.4",
		"@vitest/coverage-v8": "^4.1.10",
		"dependency-cruiser": "^18.0.0",
		"husky": "^9.1.7",
		"typescript": "~7.0.2",
		"vite": "^8.1.3",
		"vite-plugin-solid": "^2.11.0",
		"vitest": "^4.1.10"
	}
}
