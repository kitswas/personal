{
	"name": "personal",
	"version": "0.1.0",
	"description": "Personal Finance should be private.",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "biome check src e2e",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e:prepare": "tauri build --debug",
		"test:e2e:run": "playwright test",
		"test:e2e:report": "playwright show-report",
		"test:e2e": "pnpm test:e2e:prepare && pnpm test:e2e:run",
		"docs:graph": "depcruise src --include-only \"src/\" --output-type dot > docs/dependency-graph.dot && dot -Tsvg docs/dependency-graph.dot -o docs/dependency-graph.svg",
		"docs:typedoc": "typedoc --options typedoc.json",
		"docs:all": "pnpm docs:graph && pnpm docs:typedoc",
		"prepare": "husky"
	},
	"license": "MIT",
	"dependencies": {
		"@tauri-apps/api": "^2.11.1",
		"@tauri-apps/plugin-opener": "^2.5.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tauri-apps/cli": "^2.11.4",
		"@testing-library/svelte": "^5.4.2",
		"@vitest/coverage-v8": "^4.1.10",
		"dependency-cruiser": "^18.0.0",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"typedoc": "^0.28.20",
		"typedoc-plugin-mermaid": "^1.12.0",
		"typescript": "~7.0.2",
		"vite": "^8.1.3",
		"vitest": "^4.1.10"
	}
}
